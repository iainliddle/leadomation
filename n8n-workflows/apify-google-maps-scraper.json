    {
      "parameters": {
        "jsCode": "// Poll Apify run status using $http — bypasses HTTP Request node\nconst APIFY_TOKEN = 'apify_api_XcY02kFIIUHoV0YoC58jhgL5qvFEYI0RD2yF';\nconst runId = $('Fire Apify Run').item.json.data.data.id;\n\nconst response = await $http.request({\n  method: 'GET',\n  url: `https://api.apify.com/v2/actor-runs/${runId}?token=${APIFY_TOKEN}`,\n  json: true,\n});\n\nconst status = response.data.status;\nconst datasetId = response.data.defaultDatasetId;\n\nlet progress = 30;\nif (status === 'RUNNING') progress = 40;\nif (status === 'SUCCEEDED') progress = 70;\nif (status === 'FAILED' || status === 'ABORTED') progress = 0;\n\nreturn [{\n  json: {\n    status,\n    runId,\n    datasetId,\n    progress,\n    isTerminal: ['SUCCEEDED', 'FAILED', 'ABORTED', 'TIMED-OUT'].includes(status),\n  }\n}];"
      },
      "id": "poll-apify-status",
      "name": "Poll Apify Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1760, 200]
    },
    {
