    {
      "parameters": {
        "jsCode": "// Transform Apify Google Places results into leads table format\nconst items = $input.all();\nconst campaignId = $('Build Search Params').item.json.campaignId;\nconst userId = $('Build Search Params').item.json.userId;\n\nconst leads = [];\nfor (const item of items) {\n  const d = item.json;\n  leads.push({\n    json: {\n      campaign_id: campaignId,\n      user_id: userId,\n      company: d.title || d.name || '',\n      first_name: d.contactName || '',\n      email: d.email || d.emails?.[0] || '',\n      phone: d.phone || d.phones?.[0] || '',\n      website: d.website || d.url || '',\n      location: [d.city, d.state, d.countryCode].filter(Boolean).join(', '),\n      address: d.address || d.street || '',\n      rating: d.totalScore || d.rating || null,\n      reviews_count: d.reviewsCount || null,\n      category: d.categoryName || d.categories?.[0] || '',\n      google_maps_url: d.url || d.placeUrl || '',\n      source: 'google_maps',\n      status: 'new'\n    }\n  });\n}\n\nreturn leads;"
      },
      "id": "transform-leads",
      "name": "Transform Leads",
