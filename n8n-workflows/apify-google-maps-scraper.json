      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 200]
    },
    {
      "parameters": {
        "jsCode": "const status = $input.first().json.data.status;\nconst runId = $input.first().json.data.id;\nconst datasetId = $input.first().json.data.defaultDatasetId;\n\nlet progress = 30;\nif (status === 'RUNNING') progress = 40;\nif (status === 'SUCCEEDED') progress = 70;\nif (status === 'FAILED' || status === 'ABORTED') progress = 0;\n\nreturn [{\n  json: {\n    status,\n    runId,\n    datasetId,\n    progress,\n    isTerminal: ['SUCCEEDED', 'FAILED', 'ABORTED', 'TIMED-OUT'].includes(status)\n  }\n}];"
      },
      "id": "check-run-status",
      "name": "Check Run Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1760, 200]
    },
    {
