    {
      "parameters": {
        "jsCode": "// Fetch Apify dataset results using $http — bypasses HTTP Request node\nconst APIFY_TOKEN = 'apify_api_XcY02kFIIUHoV0YoC58jhgL5qvFEYI0RD2yF';\nconst datasetId = $('Poll Apify Status').item.json.datasetId;\n\nconst response = await $http.request({\n  method: 'GET',\n  url: `https://api.apify.com/v2/datasets/${datasetId}/items?token=${APIFY_TOKEN}`,\n  json: true,\n});\n\n// response is an array of place objects\nconst items = Array.isArray(response) ? response : [response];\nreturn items.map(item => ({ json: item }));"
      },
      "id": "fetch-apify-results",
      "name": "Fetch Apify Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2420, 100]
    },
