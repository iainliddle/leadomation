    {
      "parameters": {
        "jsCode": "// Build the search string from webhook data\nconst input = $input.first().json;\nconst industry = input.body.industry || '';\nconst location = input.body.location || '';\nconst city = input.body.city || '';\nconst maxLeads = input.body.max_leads || 10;\nconst campaignId = input.body.campaign_id;\nconst userId = input.body.user_id;\n\n// Build search query: \"Industry Country City\"\nlet searchQuery = industry;\nif (location) searchQuery += ' ' + location;\nif (city) searchQuery += ' ' + city;\n\nreturn [{\n  json: {\n    searchQuery,\n    maxLeads,\n    campaignId,\n    userId\n  }\n}];"
      },
      "id": "build-search-params",
      "name": "Build Search Params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "jsCode": "// Bypass HTTP Request node entirely — use $http to POST JSON to Apify\nconst APIFY_TOKEN = 'apify_api_XcY02kFIIUHoV0YoC58jhgL5qvFEYI0RD2yF';\nconst searchQuery = $input.first().json.searchQuery;\nconst maxLeads = $input.first().json.maxLeads;\n\ntry {\n  const response = await $http.request({\n    method: 'POST',\n    url: `https://api.apify.com/v2/acts/compass~crawler-google-places/runs?token=${APIFY_TOKEN}`,\n    headers: {\n      'Content-Type': 'application/json',\n    },\n    body: {\n      searchStringsArray: [searchQuery],\n      maxCrawledPlacesPerSearch: maxLeads,\n      language: 'en',\n    },\n    json: true,\n  });\n\n  return [{\n    json: {\n      success: true,\n      data: response,\n    }\n  }];\n} catch (error) {\n  return [{\n    json: {\n      success: false,\n      error: {\n        message: error.message || 'Unknown error starting Apify run',\n        statusCode: error.statusCode || 500,\n      }\n    }\n  }];\n}"
      },
      "id": "fire-apify-run",
      "name": "Fire Apify Run",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
