    {
      "parameters": {
        "jsCode": "// Build the search string from webhook data\nconst input = $input.first().json;\nconst industry = input.body.industry || '';\nconst location = input.body.location || '';\nconst city = input.body.city || '';\nconst maxLeads = input.body.max_leads || 10;\nconst campaignId = input.body.campaign_id;\nconst userId = input.body.user_id;\n\n// Build search query: \"Industry Country City\"\nlet searchQuery = industry;\nif (location) searchQuery += ' ' + location;\nif (city) searchQuery += ' ' + city;\n\nreturn [{\n  json: {\n    searchQuery,\n    maxLeads,\n    campaignId,\n    userId\n  }\n}];"
      },
      "id": "build-search-params",
      "name": "Build Search Params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/compass~crawler-google-places/runs",
        "authentication": "none",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "apify_api_XcY02kFIIUHoV0YoC58jhgL5qvFEYI0RD2yF"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ searchStringsArray: [$json.searchQuery], maxCrawledPlacesPerSearch: $json.maxLeads, language: \"en\" }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "fire-apify-run",
      "name": "Fire Apify Run",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
