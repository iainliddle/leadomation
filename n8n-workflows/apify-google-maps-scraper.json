        "tableId": "campaigns",
        "filterType": "string",
        "filterString": "id=eq.{{ $('Build Search Params').item.json.campaignId }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "progress": "={{ $json.progress }}",
            "scraping_status": "={{ $json.status === 'SUCCEEDED' ? 'processing' : ($json.isTerminal ? 'failed' : 'running') }}"
          }
        }
      },
      "id": "update-campaign-progress",
