{
    "installCommand": "npm install --legacy-peer-deps",
    "build": {
        "env": {
            "NPM_FLAGS": "--legacy-peer-deps"
        }
    },
    "redirects": [
        {
            "source": "/((?!api|coming-soon|logo-full|cancellation-feedback|favicon).*)",
            "destination": "/coming-soon.html",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/cancellation-feedback.html",
            "destination": "/cancellation-feedback.html"
        }
    ]
}